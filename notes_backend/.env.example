# Backend environment (example)
# NOTE: Do not commit real secrets. The platform will provide actual values via .env.

# --- Database (notes_database defaults) ---
# Preferred: full DSN (can be postgresql://... or postgres://...; backend converts to asyncpg driver)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5001/notemaster

# Fallback pieces (used only if POSTGRES_URL is not set)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notemaster
POSTGRES_PORT=5001

# --- CORS / frontend integration ---
# Tighten CORS in deployed environments (optional). Comma-separated list of allowed origins.
# If not set, backend allows all origins ("*") for preview/MVP.
CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-frontend.example
# Convenience single origin (added to allow list)
FRONTEND_URL=http://localhost:3000
